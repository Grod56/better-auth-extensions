{
	"name": "@better-auth-extensions/yandex",
	"version": "1.0.3",
	"description": "Yandex extensions for better-auth",
	"homepage": "https://github.com/Grod56/better-auth-extensions/tree/main/packages/yandex",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Grod56/better-auth-extensions.git",
		"directory": "packages/yandex"
	},
	"keywords": [
		"yandex",
		"better-auth",
		"auth",
		"nextjs"
	],
	"license": "MIT",
	"author": "Grod56",
	"type": "module",
	"module": "./dist/index.mjs",
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/**/*"
	],
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"clean": "del-cli ./dist",
		"build": "npm run clean && rollup -c",
		"prepack": "npm run build",
		"prepublishOnly": "npm test",
		"test": "jest",
		"test:cov": "jest --coverage --coverageReporters=json-summary --coverageProvider=v8",
		"lint:native": "tsc --noEmit",
		"format": "prettier --write .",
		"check:src": "npm run lint:native && npm run test"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"del-cli": "^7.0.0",
		"globals": "^17.6.0",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"jest-ts-webcompat-resolver": "^1.0.1",
		"ts-jest": "^29.4.9",
		"ts-node": "^10.9.2"
	}
}
